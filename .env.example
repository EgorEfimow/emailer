# =============================================================================
# Email AI Agent — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values. Environment variables
# override YAML/JSON config file values, which in turn override defaults.
#
#   cp .env.example .env
#   # edit .env with your secrets
#   ./emailer --config config.yaml
#
# All variables are optional — set only what you need to override.
# =============================================================================

# ---------------------------------------------------------------------------
# LLM Provider
# ---------------------------------------------------------------------------
# Supported providers: gemini, ollama, openrouter

# For Gemini:
# EMAILER_LLM_PROVIDER=gemini
# EMAILER_LLM_API_KEY=your-api-key-here
# EMAILER_LLM_MODEL=gemini-2.0-flash
# EMAILER_LLM_ENDPOINT=                          # optional override
# EMAILER_LLM_TIMEOUT=120s
# EMAILER_LLM_MAX_RETRIES=3
# EMAILER_LLM_MAX_CONCURRENT=4
# EMAILER_LLM_ANALYSIS_REPAIR_MAX_ATTEMPTS=1

# For OpenRouter (remote, OpenAI-compatible gateway; API key in Authorization: Bearer header):
# EMAILER_LLM_PROVIDER=openrouter
# EMAILER_LLM_API_KEY=sk-or-v1-your-openrouter-key
# EMAILER_LLM_MODEL=openai/gpt-4o
# EMAILER_LLM_ENDPOINT=https://openrouter.ai/api/v1  # optional override
# EMAILER_LLM_TIMEOUT=120s
# EMAILER_LLM_MAX_RETRIES=3
# EMAILER_LLM_MAX_CONCURRENT=4
# EMAILER_LLM_ANALYSIS_REPAIR_MAX_ATTEMPTS=1

# For Ollama (local, no API key required):
# EMAILER_LLM_PROVIDER=ollama
# EMAILER_LLM_API_KEY=                           # optional, not used by Ollama
# EMAILER_LLM_MODEL=llama3.2
# EMAILER_LLM_ENDPOINT=http://localhost:11434/api
# EMAILER_LLM_TIMEOUT=120s
# EMAILER_LLM_MAX_RETRIES=3
# EMAILER_LLM_MAX_CONCURRENT=4
# EMAILER_LLM_ANALYSIS_REPAIR_MAX_ATTEMPTS=1

# ---------------------------------------------------------------------------
# IMAP Accounts
# ---------------------------------------------------------------------------
# Define accounts as a JSON array. Each account supports:
#   label, host, port, username, password, folders, use_tls

# EMAILER_IMAP_ACCOUNTS=[{"label":"work","host":"imap.example.com","port":993,"username":"user@example.com","password":"secret","folders":["INBOX"],"use_tls":true}]

# Per-command IMAP timeout (dial, login, select, fetch, store). 0 = no timeout.
# EMAILER_IMAP_TIMEOUT=30s

# ---------------------------------------------------------------------------
# Telegram Notification
# ---------------------------------------------------------------------------

# EMAILER_NOTIFY_TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
# EMAILER_NOTIFY_TELEGRAM_CHAT_ID=-1001234567890

# ---------------------------------------------------------------------------
# Storage
# ---------------------------------------------------------------------------

# EMAILER_STORAGE_STATE_PATH=./state/emailer.db
# EMAILER_STORAGE_STATELESS=false

# ---------------------------------------------------------------------------
# Fetch Behaviour
# ---------------------------------------------------------------------------

# EMAILER_FETCH_UNREAD_ONLY=false
# EMAILER_MAX_WINDOW=72h

# ---------------------------------------------------------------------------
# Digest
# ---------------------------------------------------------------------------

# EMAILER_DIGEST_MAX_MESSAGE_EXCERPT=500
# EMAILER_DIGEST_INCLUDE_READ_STATUS=true
# EMAILER_DIGEST_INCLUDE_GLOBAL_STATS=true
# EMAILER_DIGEST_INCLUDE_ACCOUNT_STATS=true
# EMAILER_DIGEST_INCLUDE_SUMMARIES=true
# EMAILER_DIGEST_INCLUDE_KEY_POINTS=true
# EMAILER_DIGEST_INCLUDE_ACTION_ITEMS=true
# EMAILER_DIGEST_INCLUDE_RAW_EXCERPT_FALLBACK=true
# EMAILER_DIGEST_MAX_MESSAGES=100
# EMAILER_DIGEST_MAX_KEY_POINTS_PER_MESSAGE=5
# EMAILER_DIGEST_MAX_ACTION_ITEMS_PER_MESSAGE=3
# EMAILER_DIGEST_PRIORITY_ONLY=false
# EMAILER_DIGEST_INCLUDE_GLOBAL_STATS=true
# EMAILER_DIGEST_INCLUDE_ACCOUNT_STATS=true
# EMAILER_DIGEST_INCLUDE_SUMMARIES=true
# EMAILER_DIGEST_INCLUDE_KEY_POINTS=true
# EMAILER_DIGEST_INCLUDE_ACTION_ITEMS=true
# EMAILER_DIGEST_INCLUDE_RAW_EXCERPT_FALLBACK=true
# EMAILER_DIGEST_MAX_MESSAGES=100
# EMAILER_DIGEST_MAX_KEY_POINTS_PER_MESSAGE=5
# EMAILER_DIGEST_MAX_ACTION_ITEMS_PER_MESSAGE=3
# EMAILER_DIGEST_PRIORITY_ONLY=false

# ---------------------------------------------------------------------------
# Labels
# ---------------------------------------------------------------------------
# Custom classification labels beyond the built-in Useful, ToDelete, Ads.

# EMAILER_LABELS_CUSTOM=["Urgent","Reference"]

# ---------------------------------------------------------------------------
# Concurrency
# ---------------------------------------------------------------------------

# EMAILER_CONCURRENCY_MAX_ACCOUNTS=4
# EMAILER_CONCURRENCY_MAX_LLM_CALLS=4
# EMAILER_CONCURRENCY_FETCH_BATCH_SIZE=10